# ============================================================
# LegalAgent Docker environment variables
# Copy before use: cp .env.docker.example .env.docker
# ============================================================

# -- PostgreSQL --
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=legal_db
PG_URL=postgresql://postgres:123456@postgres:5432/legal_db

# -- LLM inference (vLLM internal address) --
base_url=http://vllm:8888/v1
api_key=EMPTY
VLLM_LORA_NAME=legal-lora
GEN_MODEL=legal-lora

# -- External LLM API (uncomment if not using local vLLM) --
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# GEN_MODEL=gpt-4o

# -- Tavily search --
tavily_api_key=

# -- Agent API (browser-facing address for UI) --
agent_base_url=http://localhost:8008/v1

# -- Embedding / Reranker --
embed_model=BAAI/bge-large-zh-v1.5
embed_dim=1024
reranker_model=BAAI/bge-reranker-v2-m3

# -- vLLM service options --
VLLM_HOST=0.0.0.0
VLLM_PORT=8888
VLLM_TP_SIZE=1
VLLM_MAX_MODEL_LEN=4096
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_DTYPE=bfloat16
VLLM_QUANTIZATION=bitsandbytes
VLLM_ENABLE_TOOL_CALL=true
VLLM_LANGUAGE_MODEL_ONLY=true
VLLM_ENFORCE_EAGER=false
VLLM_ENABLE_PREFIX_CACHING=true
VLLM_ENABLE_CHUNKED_PREFILL=true
VLLM_ENABLE_LORA=true
