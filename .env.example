PG_URL=postgresql://postgres:123456@localhost:5432/legal_db

embed_model=BAAI/bge-large-zh-v1.5
embed_dim=1024
batch_size=128
hnsw_m=16
hnsw_ef_construction=64
hnsw_ef_search=40
hnsw_dist_method=vector_cosine_ops

reranker_model=BAAI/bge-reranker-v2-m3

# -- vLLM 部署配置 --
# VLLM_MODEL_PATH=./LLM/qwen3.5-9b
VLLM_HOST=0.0.0.0
VLLM_PORT=8888
VLLM_TP_SIZE=1
VLLM_MAX_MODEL_LEN=4096
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_DTYPE=bfloat16
VLLM_ENABLE_TOOL_CALL=true
VLLM_LANGUAGE_MODEL_ONLY=true
VLLM_QUANTIZATION=bitsandbytes
# 性能优化
VLLM_ENFORCE_EAGER=false
VLLM_ENABLE_PREFIX_CACHING=true
VLLM_ENABLE_CHUNKED_PREFILL=true

# -- LoRA 适配器配置 --
VLLM_ENABLE_LORA=true
VLLM_LORA_NAME=legal-lora
# VLLM_LORA_PATH=./LLM/qwen3.5-9b-lora
# VLLM_MAX_LORA_RANK=64

base_url=http://0.0.0.0:8888/v1
api_key=EMPTY

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
GEN_MODEL=gpt-5.4-nano-2026-03-17

tavily_api_key=your_tavily_api_key_here
tavily_base_url=https://mcp.tavily.com/mcp/?tavilyApiKey=your_tavily_api_key_here

agent_base_url=http://0.0.0.0:8008/v1
UI_base_url=http://0.0.0.0:8009
